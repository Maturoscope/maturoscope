<html>

<head>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <%- include(baseDir + '/pdf/styles.ejs' ) %>
</head>

<%
  var scaleMap = {
    trl: { data: reportData.trl, stageTranslation: t.overview.stages.trl },
    mkrl: { data: reportData.mkrl, stageTranslation: t.overview.stages.mkrl },
    mfrl: { data: reportData.mfrl, stageTranslation: t.overview.stages.mfrl }
  };
%>

<body class="bg-[#F5F5F5]">
  <% pages.forEach(function(page) { %>
    <main class="w-[1440px] h-[2040px] aspect-ratio-1440/2040 flex flex-col gap-4">
      <%- include(baseDir + '/pdf/nav.ejs' , { t, reportData }) %>

      <div class="w-full h-full px-6">
        <% page.blocks.forEach(function(block) { %>

          <% if (block.type === 'overview') { %>
            <!-- Overview section -->
            <div class="flex flex-col gap-1.5 mb-9">
              <h1 class="text-3xl font-bold">
                <%= t.report.title %>
              </h1>
              <% if (reportData.projectName) { %>
                <p class="text-xl font-medium">
                  <%= reportData.projectName %>
                </p>
              <% } %>
              <p class="text-sm text-muted-foreground">
                <%= t.report.completedOn %>
                <%= reportData.completedOn %>
              </p>
            </div>

            <div class="flex flex-col gap-6 mb-9">
              <h2 class="text-2xl font-semibold">
                <%= t.overview.title %>
              </h2>

              <div class="flex gap-6 items-center justify-between">
                <%- include(baseDir + '/pdf/overview-card.ejs' , { t, scale: reportData.trl, stageTranslation: t.overview.stages.trl, color: '#EA580C' , baseDir }) %>
                <%- include(baseDir + '/pdf/overview-card.ejs' , { t, scale: reportData.mkrl, stageTranslation: t.overview.stages.mkrl, color: '#0D9488' , baseDir }) %>
                <%- include(baseDir + '/pdf/overview-card.ejs' , { t, scale: reportData.mfrl, stageTranslation: t.overview.stages.mfrl, color: '#2563EB' , baseDir }) %>
              </div>
            </div>

          <% } else if (block.type === 'detailed-title') { %>
            <!-- Detailed report title -->
            <div class="flex flex-col gap-6">
              <div class="flex flex-col gap-1.5">
                <h2 class="text-2xl font-semibold">
                  <%= t.detailedReport.title %>
                </h2>
                <p class="text-sm text-[#171717]">
                  <%= t.detailedReport.description %>
                </p>
              </div>
            </div>

          <% } else if (block.type === 'detailed-card') { %>
            <!-- Detailed card for scale -->
            <% var scaleInfo = scaleMap[block.scaleKey]; %>
            <div class="flex flex-col gap-6 mt-6">
              <%- include(baseDir + '/pdf/detailed-card.ejs' , {
                t,
                scale: scaleInfo.data,
                stageTranslation: scaleInfo.stageTranslation,
                color: block.color,
                indexBgColor: block.indexBgColor,
                baseDir,
                gapSlices: block.gapSlices,
                isFirstPageOfScale: block.isFirstPageOfScale
              }) %>
            </div>

          <% } else if (block.type === 'answers-section') { %>
            <!-- Answers for a scale -->
            <% var answerScaleInfo = scaleMap[block.scaleKey]; %>
            <% if (block.showTitle) { %>
              <h1 class="text-2xl font-semibold mb-6 mt-8">
                <%= t.answers.title %>
              </h1>
            <% } %>
            <div class="flex flex-col gap-4 mb-9">
              <% if (block.showLabel) { %>
                <span class="text-xl font-semibold"><%= answerScaleInfo.stageTranslation.label %></span>
              <% } %>
              <div class="flex flex-col gap-2">
                <% var answers = answerScaleInfo.data.answers.slice(block.answerStartIndex, block.answerEndIndex); %>
                <% answers.forEach(function(answer) { %>
                  <%- include(baseDir + '/pdf/answer-card.ejs' , { answer, t }) %>
                <% }) %>
              </div>
            </div>

          <% } else if (block.type === 'disclaimer') { %>
            <!-- Disclaimer -->
            <p class="text-sm text-muted-foreground max-w-[825px] text-center mt-8 mx-auto">
              <%= t.footer.disclaimer %>
            </p>

          <% } %>

        <% }) %>
      </div>

      <%- include(baseDir + '/pdf/footer.ejs' , { t }) %>
    </main>
  <% }) %>
</body>

</html>
