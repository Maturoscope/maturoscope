<% var services = gap.hasServices ? gap.recommendedServices.slice(serviceStartIndex, serviceEndIndex) : []; %>

<% if (showGapHeader) { %>
  <div class="flex gap-2 items-start justify-between w-full pt-4 pb-6 border-b border-border last:border-b-0">
    <div class="size-6 flex items-center justify-center <%= indexBgColor %> shrink-0 rounded text-sm font-medium"><%= index + 1 %></div>
    <div class="flex flex-col w-full">
      <span class="mb-4 font-semibold"><%= gap.gapDescription %></span>
      <% if (gap.hasServices) { %>
        <span class="uppercase text-xs font-semibold text-[#0D9488] mb-2.5"><%= gap.recommendedServices.length > 1 ? t.detailedReport.servicesAvailable : t.detailedReport.serviceAvailable %></span>
        <div class="flex flex-col">
          <% services.forEach(function(service, sIdx) { %>
            <div class="flex flex-col gap-1 <%= sIdx !== 0 ? 'border-t border-[#E5E5E5] pt-3 mt-4' : '' %>">
              <span class="text-base font-medium"><%= service.name %></span>
              <span class="text-sm text-muted-foreground max-w-[900px]"><%= service.description %></span>
              <% if (service.url) { %>
                <div class="flex items-center gap-1.5 mt-2.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0A0A0A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  <span class="text-sm text-[#0A0A0A]"><%= service.url %></span>
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <span class="uppercase text-xs font-semibold text-muted-foreground"><%= t.detailedReport.comingSoon %></span>
      <% } %>
    </div>
  </div>
<% } else { %>
  <!-- Continuation: services only (no gap header) -->
  <div class="flex gap-2 items-start justify-between w-full pb-6 border-b border-border last:border-b-0">
    <div class="size-6 shrink-0"></div>
    <div class="flex flex-col w-full">
      <div class="flex flex-col">
        <% services.forEach(function(service, sIdx) { %>
          <div class="flex flex-col gap-1 <%= sIdx !== 0 ? 'border-t border-[#E5E5E5] pt-3 mt-4' : '' %>">
            <span class="text-base font-medium"><%= service.name %></span>
            <span class="text-sm text-muted-foreground max-w-[900px]"><%= service.description %></span>
            <% if (service.url) { %>
              <div class="flex items-center gap-1.5 mt-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0A0A0A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                <span class="text-sm text-[#0A0A0A]"><%= service.url %></span>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
<% } %>
