# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_secure_password_here
DB_NAME=maturoscope

# API Server Configuration
PORT=8000
NODE_ENV=development

# Auth0 Configuration
# Get these values from your Auth0 dashboard: https://manage.auth0.com/
AUTH0_ISSUER_URL=https://your-auth0-domain.auth0.com/
AUTH0_AUDIENCE=http://localhost:8000/
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_USER_ROLE=rol_your_user_role_id
AUTH0_ADMIN_ROLE=rol_your_admin_role_id

# OVH S3 Storage (Optional for local development)
# Leave empty if you don't need file uploads in development
OVH_S3_ENDPOINT=https://s3.eu-west-par.io.cloud.ovh.net
OVH_S3_PUBLIC_BASE_URL=https://your-bucket.s3.eu-west-par.io.cloud.ovh.net
OVH_S3_REGION=eu-west-par
OVH_S3_ACCESS_KEY=your_access_key
OVH_S3_SECRET_KEY=your_secret_key
OVH_S3_BUCKET=your_bucket_name

# Email Configuration (Gmail SMTP)
# Generate a secure random string for JWT_SECRET (minimum 32 characters)
JWT_SECRET=your_jwt_secret_here_min_32_chars
INVITATION_TOKEN_EXPIRATION=7d
DASHBOARD_APP_URL=http://localhost:3001
INVITATION_EXPIRATION_DAYS=7

# Gmail OAuth2 Credentials
# Follow Google Cloud Console setup to get these values
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
MAIL_USER=your_email@gmail.com
MAIL_FROM=your_email@gmail.com
APP_NAME=Maturoscope
