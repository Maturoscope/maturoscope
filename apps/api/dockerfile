# ---------------------------
# BASE (common tools)
# ---------------------------
# Updated: 2026-02-10-20:21 
FROM node:20-alpine AS base
WORKDIR /app
ENV NODE_ENV=production
ENV NODE_OPTIONS="--max-old-space-size=4096"

# Enable Yarn Berry (Yarn 3) - only for build
RUN corepack enable

# ---------------------------
# PRUNNER (turbo prune)
# ---------------------------
FROM base AS prunner
# Minimal files for prune
COPY package.json yarn.lock turbo.json .yarnrc.yml ./
COPY apps/api/package.json ./apps/api/

# Use yarn install without --immutable to allow lockfile updates
RUN yarn install --network-timeout 300000
COPY . .
# Workaround for TypeScript patches in CI/CD
RUN echo "compressionLevel: mixed" > .yarnrc-temp.yml && \
    echo "enableGlobalCache: false" >> .yarnrc-temp.yml && \
    echo "nodeLinker: node-modules" >> .yarnrc-temp.yml && \
    mv .yarnrc.yml .yarnrc.yml.backup && \
    mv .yarnrc-temp.yml .yarnrc.yml && \
    rm -f yarn.lock && \
    yarn install --network-timeout 300000 && \
    yarn turbo prune api --docker

# ---------------------------
# BUILDER (install and compile)
# ---------------------------
FROM base AS builder
WORKDIR /app

# Bring pruned tree and lockfile
COPY --from=prunner /app/out/json/ .
COPY --from=prunner /app/out/yarn.lock ./yarn.lock

# Install dependencies (node_modules)
RUN yarn install

# Copy pruned code
COPY --from=prunner /app/out/full/ .

# Ensure all dependencies are available
# Copy complete API package.json
COPY apps/api/package.json ./apps/api/package.json

# Install all API dependencies explicitly
RUN yarn add @nestjs/typeorm typeorm @nestjs/core @nestjs/common @nestjs/platform-express

# Compile the API
RUN yarn turbo run build --filter=api

# ---------------------------
# RUNTIME (Debian slim for Chromium compatibility)
# ---------------------------
FROM node:20-slim AS runner
WORKDIR /app
ENV NODE_ENV=production

# Install Chromium and required dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    fonts-freefont-ttf \
    fonts-noto-color-emoji \
    ca-certificates \
    dbus \
    && rm -rf /var/lib/apt/lists/*

# Set Chromium path for Puppeteer
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Create non-root user
RUN groupadd --system --gid 1001 app \
    && useradd --system --uid 1001 --gid app app

# Copy only what's needed to run the compiled API
# 1) compiled dist
COPY --from=builder --chown=app:app /app/apps/api/dist ./dist
# 2) API package.json (needed for Node.js)
COPY --from=builder --chown=app:app /app/apps/api/package.json ./package.json
# 3) complete node_modules from builder (includes all pruned dependencies)
COPY --from=builder --chown=app:app /app/node_modules ./node_modules

# Verify critical PDF assets exist
RUN test -s dist/modules/report/pdf/template.ejs || (echo "ERROR: template.ejs missing or empty" && exit 1) \
    && test -s dist/modules/report/pdf/compiled.css || (echo "ERROR: compiled.css missing or empty" && exit 1) \
    && test -s dist/modules/report/pdf/locales/en.json || (echo "ERROR: en.json locale missing or empty" && exit 1)

# Switch to non-root user
USER app

# Exposed port
EXPOSE 8000

# Run migrations and then start the application
CMD ["sh", "-c", "node dist/run-migrations.js && node dist/main.js"]