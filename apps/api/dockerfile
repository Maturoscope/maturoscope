# ---------------------------
# BASE (herramientas comunes)
# ---------------------------
    FROM node:20-alpine AS base
    WORKDIR /app
    ENV NODE_ENV=production
    ENV NODE_OPTIONS="--max-old-space-size=4096"
    
    # Habilitamos corepack SOLO en stages de build
    RUN corepack enable
    
    # ---------------------------
    # PRUNNER (turbo prune)
    # ---------------------------
    FROM base AS prunner
    # Archivos mínimos para prune
    COPY package.json yarn.lock turbo.json .yarnrc.yml ./
    COPY apps/api/package.json ./apps/api/
    COPY packages/ ./packages/
    RUN yarn install --immutable
    COPY . .
    RUN yarn turbo prune api --docker
    
    # ---------------------------
    # BUILDER (instala y compila)
    # ---------------------------
    FROM base AS builder
    WORKDIR /app
    
    # Traemos el árbol pruned y lockfile resultante
    COPY --from=prunner /app/out/json/ .
    COPY --from=prunner /app/out/yarn.lock ./yarn.lock
    
    # Instalamos dependencias (node_modules)
    RUN yarn install --immutable
    
    # Copiamos el código pruned y compilamos solo la API
    COPY --from=prunner /app/out/full/ .
    RUN yarn turbo run build --filter=api
    
    # Opcional: reducir solo a deps de prod para la API
    # (si tus workspaces lo soportan)
    # RUN yarn workspaces focus api --production
    
    # ---------------------------
    # RUNTIME (ligero, sin yarn)
    # ---------------------------
    FROM node:20-alpine AS runner
    WORKDIR /app
    ENV NODE_ENV=production
    # NOTA: NO habilites corepack acá; no queremos yarn en runtime.
    
    # Copiamos artefactos necesarios para ejecutar la API
    # 1) dist compilado
    COPY --from=builder /app/apps/api/dist ./dist
    # 2) package.json de la API (opcional si tu app lo usa)
    COPY --from=builder /app/apps/api/package.json ./package.json
    # 3) node_modules si tu API los necesita en runtime
    #    (si usás nodeLinker: node-modules)
    COPY --from=builder /app/node_modules ./node_modules
    
    # Puerto expuesto
    EXPOSE 8000
    
    # Ejecutar Nest compilado
    CMD ["node", "dist/main.js"]