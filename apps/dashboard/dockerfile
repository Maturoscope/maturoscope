# --------------------------------------------------------------------------------------------------------------------
# BASE
# --------------------------------------------------------------------------------------------------------------------
    FROM node:20-alpine AS base

    # Directorio de trabajo
    WORKDIR /app
    
    # Variables comunes
    ENV NODE_OPTIONS="--max-old-space-size=4096"
    
    # Habilitar Yarn Berry (Yarn 3)
    RUN corepack enable
    
    # --------------------------------------------------------------------------------------------------------------------
    # PRUNER (Optimization with Turbo)
    # --------------------------------------------------------------------------------------------------------------------
    FROM base AS prunner
    
    # Copy only what's needed for the prune
    COPY package.json yarn.lock ./
    COPY turbo.json ./
    COPY .yarnrc.yml ./
    COPY apps/dashboard/package.json ./apps/dashboard/
    
    # Install dependencies needed for turbo prune
    RUN yarn install
    
    # Copy source code for the prune
    COPY . .
    
    # Prune to generate minimal files for Docker installation
    RUN yarn turbo prune dashboard --docker
    
    # --------------------------------------------------------------------------------------------------------------------
    # INSTALLER (Installation and Build)
    # --------------------------------------------------------------------------------------------------------------------
    FROM base AS installer
    
    WORKDIR /app
    
    # Copy package.json and lockfiles resulting from prune
    COPY --from=prunner /app/out/json/ .
    COPY --from=prunner /app/out/yarn.lock ./yarn.lock
    
    # Install dependencies
    RUN yarn install --immutable
    
    # Copy the rest of the pruned code
    COPY --from=prunner /app/out/full/ .
    
    # Environment configuration
    ARG NODE_ENV=production
    ENV NODE_ENV=${NODE_ENV}
    
    # Environment variables for Next.js
    ARG NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
    ARG NEXT_PUBLIC_GATEWAY_URL
    ENV NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=$NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
    ENV NEXT_PUBLIC_GATEWAY_URL=$NEXT_PUBLIC_GATEWAY_URL
    
    # Auth0 variables (environment-specific)
    ARG AUTH0_CLIENT_SECRET
    ARG AUTH0_SECRET
    
    # DEBUG: Check if build args are received (with timestamp to avoid cache)
    RUN echo "=== BUILD DEBUG $(date) ===" && \
        echo "AUTH0_CLIENT_SECRET length: ${#AUTH0_CLIENT_SECRET}" && \
        echo "AUTH0_SECRET length: ${#AUTH0_SECRET}" && \
        echo "AUTH0_CLIENT_SECRET value: ${AUTH0_CLIENT_SECRET:0:8}..." && \
        echo "AUTH0_SECRET value: ${AUTH0_SECRET:0:8}..." && \
        echo "=================="
    
    # Embed secrets at build time for Next.js
    ENV AUTH0_CLIENT_SECRET=$AUTH0_CLIENT_SECRET
    ENV AUTH0_SECRET=$AUTH0_SECRET
    
    # Save secrets to files for runner stage (create /tmp/secrets directory)
    RUN mkdir -p /tmp/secrets && \
        echo "$AUTH0_CLIENT_SECRET" > /tmp/secrets/auth0_client_secret && \
        echo "$AUTH0_SECRET" > /tmp/secrets/auth0_secret && \
        echo "Secrets saved to files for runner stage"
    
    # Build only the dashboard service
    RUN yarn turbo run build --filter=dashboard
    
    # --------------------------------------------------------------------------------------------------------------------
    # RUNNER (Final execution)
    # --------------------------------------------------------------------------------------------------------------------
    FROM base AS runner

ARG NODE_ENV=production
ENV NODE_ENV=${NODE_ENV}

# Copy secrets from installer stage
COPY --from=installer /tmp/secrets /tmp/secrets

# Read secrets from files and set as environment variables
RUN echo "=== RUNNER DEBUG $(date) ===" && \
    echo "Reading secrets from files..." && \
    if [ -f "/tmp/secrets/auth0_client_secret" ]; then \
        export AUTH0_CLIENT_SECRET="$(cat /tmp/secrets/auth0_client_secret)" && \
        echo "AUTH0_CLIENT_SECRET file found, length: ${#AUTH0_CLIENT_SECRET}"; \
    else \
        echo "AUTH0_CLIENT_SECRET file NOT found"; \
    fi && \
    if [ -f "/tmp/secrets/auth0_secret" ]; then \
        export AUTH0_SECRET="$(cat /tmp/secrets/auth0_secret)" && \
        echo "AUTH0_SECRET file found, length: ${#AUTH0_SECRET}"; \
    else \
        echo "AUTH0_SECRET file NOT found"; \
    fi && \
    echo "=================="

# Create startup script that loads env vars and starts the app
RUN AUTH0_CLIENT_SECRET="$(cat /tmp/secrets/auth0_client_secret 2>/dev/null || echo '')" && \
    AUTH0_SECRET="$(cat /tmp/secrets/auth0_secret 2>/dev/null || echo '')" && \
    echo '#!/bin/sh' > /tmp/start-dashboard.sh && \
    echo 'echo "=== LOADING ENV VARS ==="' >> /tmp/start-dashboard.sh && \
    echo "export AUTH0_CLIENT_SECRET='$AUTH0_CLIENT_SECRET'" >> /tmp/start-dashboard.sh && \
    echo "export AUTH0_SECRET='$AUTH0_SECRET'" >> /tmp/start-dashboard.sh && \
    echo 'echo "AUTH0_CLIENT_SECRET loaded: $([ -n \"$AUTH0_CLIENT_SECRET\" ] && echo \"YES\" || echo \"NO\")"' >> /tmp/start-dashboard.sh && \
    echo 'echo "AUTH0_SECRET loaded: $([ -n \"$AUTH0_SECRET\" ] && echo \"YES\" || echo \"NO\")"' >> /tmp/start-dashboard.sh && \
    echo 'echo "AUTH0_CLIENT_SECRET length: ${#AUTH0_CLIENT_SECRET}"' >> /tmp/start-dashboard.sh && \
    echo 'echo "AUTH0_SECRET length: ${#AUTH0_SECRET}"' >> /tmp/start-dashboard.sh && \
    echo 'echo "==========================="' >> /tmp/start-dashboard.sh && \
    echo 'echo "Starting Next.js application..."' >> /tmp/start-dashboard.sh && \
    echo 'exec yarn turbo run start --filter=dashboard' >> /tmp/start-dashboard.sh && \
    chmod +x /tmp/start-dashboard.sh && \
    echo "Startup script created with embedded variables"

# Clean up secrets files
RUN rm -rf /tmp/secrets && echo "Secrets files cleaned up"
    
    # Create non-root user
    RUN addgroup --system --gid 1001 dashboard \
        && adduser --system --uid 1001 dashboard
    
    USER dashboard
    
    # Copy only necessary files for production
    COPY --from=installer --chown=dashboard:dashboard /app .
    
    # Expose dashboard port
    EXPOSE 3001
    
    # Execute the startup script that exports variables and starts the app
CMD ["/tmp/start-dashboard.sh"]
    