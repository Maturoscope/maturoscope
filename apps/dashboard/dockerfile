# --------------------------------------------------------------------------------------------------------------------
# BASE
# --------------------------------------------------------------------------------------------------------------------
    FROM node:20-alpine AS base

    # Directorio de trabajo
    WORKDIR /app
    
    # Variables comunes
    ENV NODE_OPTIONS="--max-old-space-size=4096"
    
    # Habilitar Yarn Berry (Yarn 3)
    RUN corepack enable
    
    # --------------------------------------------------------------------------------------------------------------------
    # PRUNER (Optimization with Turbo)
    # --------------------------------------------------------------------------------------------------------------------
    FROM base AS prunner
    
    # Copy only what's needed for the prune
    COPY package.json yarn.lock ./
    COPY turbo.json ./
    COPY .yarnrc.yml ./
    COPY apps/dashboard/package.json ./apps/dashboard/
    
    # Install dependencies needed for turbo prune
    RUN yarn install
    
    # Copy source code for the prune
    COPY . .
    
    # Prune to generate minimal files for Docker installation
    RUN yarn turbo prune dashboard --docker
    
    # --------------------------------------------------------------------------------------------------------------------
    # INSTALLER (Installation and Build)
    # --------------------------------------------------------------------------------------------------------------------
    FROM base AS installer
    
    WORKDIR /app
    
    # Copy package.json and lockfiles resulting from prune
    COPY --from=prunner /app/out/json/ .
    COPY --from=prunner /app/out/yarn.lock ./yarn.lock
    
    # Install dependencies
    RUN yarn install --immutable
    
    # Copy the rest of the pruned code
    COPY --from=prunner /app/out/full/ .
    
    # Environment configuration
    ARG NODE_ENV=production
    ENV NODE_ENV=${NODE_ENV}
    
    # Environment variables for Next.js
    ARG NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
    ARG NEXT_PUBLIC_GATEWAY_URL
    ENV NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=$NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
    ENV NEXT_PUBLIC_GATEWAY_URL=$NEXT_PUBLIC_GATEWAY_URL
    
    # Auth0 variables and RSA keys (environment-specific)
    ARG AUTH0_CLIENT_SECRET
    ARG AUTH0_SECRET
    ARG PRIVATE_KEY
    ARG PUBLIC_KEY
    
    # Embed secrets at build time for Next.js
    ENV AUTH0_CLIENT_SECRET=$AUTH0_CLIENT_SECRET
    ENV AUTH0_SECRET=$AUTH0_SECRET
    ENV PRIVATE_KEY=$PRIVATE_KEY
    ENV PUBLIC_KEY=$PUBLIC_KEY
    
    # Save runtime variables to file for multi-stage persistence
    RUN echo "AUTH0_CLIENT_SECRET=$AUTH0_CLIENT_SECRET" > /tmp/runtime-vars.env && \
        echo "AUTH0_SECRET=$AUTH0_SECRET" >> /tmp/runtime-vars.env && \
        echo "PRIVATE_KEY=$PRIVATE_KEY" >> /tmp/runtime-vars.env && \
        echo "PUBLIC_KEY=$PUBLIC_KEY" >> /tmp/runtime-vars.env && \
        echo "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=$NEXT_PUBLIC_GOOGLE_MAPS_API_KEY" >> /tmp/runtime-vars.env && \
        echo "NEXT_PUBLIC_GATEWAY_URL=$NEXT_PUBLIC_GATEWAY_URL" >> /tmp/runtime-vars.env
    
    # Build only the dashboard service
    RUN yarn turbo run build --filter=dashboard
    
    # --------------------------------------------------------------------------------------------------------------------
    # RUNNER (Final execution)
    # --------------------------------------------------------------------------------------------------------------------
    FROM base AS runner
    
    ARG NODE_ENV=production
    ENV NODE_ENV=${NODE_ENV}
    
    # Copy runtime variables file from installer stage
    COPY --from=installer /tmp/runtime-vars.env /tmp/runtime-vars.env
    
    # Create startup script that loads environment variables
    RUN echo '#!/bin/bash' > /usr/local/bin/start-dashboard.sh && \
        echo 'set -a' >> /usr/local/bin/start-dashboard.sh && \
        echo '. /tmp/runtime-vars.env' >> /usr/local/bin/start-dashboard.sh && \
        echo 'set +a' >> /usr/local/bin/start-dashboard.sh && \
        echo 'echo "=== STARTUP ENV DEBUG ===" ' >> /usr/local/bin/start-dashboard.sh && \
        echo 'echo "PUBLIC_KEY loaded: $([ -n "$PUBLIC_KEY" ] && echo "YES" || echo "NO")"' >> /usr/local/bin/start-dashboard.sh && \
        echo 'echo "PRIVATE_KEY loaded: $([ -n "$PRIVATE_KEY" ] && echo "YES" || echo "NO")"' >> /usr/local/bin/start-dashboard.sh && \
        echo 'echo "======================="' >> /usr/local/bin/start-dashboard.sh && \
        echo 'exec "$@"' >> /usr/local/bin/start-dashboard.sh && \
        chmod +x /usr/local/bin/start-dashboard.sh
    
    # Create non-root user
    RUN addgroup --system --gid 1001 dashboard \
        && adduser --system --uid 1001 dashboard
    
    USER dashboard
    
    # Copy only necessary files for production
    COPY --from=installer --chown=dashboard:dashboard /app .
    
    # Expose dashboard port
    EXPOSE 3001
    
    # Startup command using our script that loads environment variables
    CMD ["/usr/local/bin/start-dashboard.sh", "yarn", "turbo", "run", "start", "--filter=dashboard"]
    